# Replace hub.example.com with your actual domain
hub.example.com {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Permissions-Policy        "clipboard-read=(), clipboard-write=(), camera=(), microphone=()"
        Content-Security-Policy   "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' wss://hub.example.com; font-src 'self' data:;"
        -Server
    }

    reverse_proxy localhost:3000 {
        transport http {
            read_timeout  3600s
            write_timeout 3600s
        }
        header_up X-Real-IP        {remote_host}
        header_up X-Forwarded-Proto https
    }
}
