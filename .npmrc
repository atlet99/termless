# pnpm 11 settings
# Force all typescript-eslint packages to v8 for ESLint 10 compatibility
override.@typescript-eslint/scope-manager=^8.59.4
override.@typescript-eslint/types=^8.59.4
override.@typescript-eslint/utils=^8.59.4
override.@typescript-eslint/visitor-keys=^8.59.4
override.@typescript-eslint/type-utils=^8.59.4
override.@typescript-eslint/tsconfig-utils=^8.59.4
override.@typescript-eslint/parser=^8.59.4
override.@typescript-eslint/eslint-plugin=^8.59.4
override.@typescript-eslint/typescript-estree=^8.59.4
override.@typescript-eslint/project-service=^8.59.4

onlyBuiltDependencies=@biomejs/biome,@prisma/engines,argon2,esbuild,prisma,unrs-resolver

# Ignore peer dependency conflict for eslint-plugin-vitest (needs v7 but we force v8)
peerDependencyRules.ignoreMissing={"@typescript-eslint/utils":{"eslint-plugin-vitest":">=0.5.0"}}