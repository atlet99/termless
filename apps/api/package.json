    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/type-provider-zod": "^1.0.0",
    "@fastify/websocket": "^11.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
