{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreDependencies": ["@types/pg", "@types/i18next"],
  "workspaces": {
    "apps/api": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/dashboard": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/auth": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/worker": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
